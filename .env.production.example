# Production API base URL (used at build time by Vite).
# Leave empty to use same-origin (/api) so nginx can proxy to your backend.
# Or set to your full API URL, e.g.:
# VITE_API_URL=https://dash.evse.cloud

VITE_API_URL=

# App version (shown in Settings). Used at build time.
VITE_APP_VERSION=0.1.0
