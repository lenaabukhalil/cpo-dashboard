        "func": "const auth = msg.req && msg.req.headers && (msg.req.headers.authorization || msg.req.headers.Authorization);\nlet organizationId = null;\nif (auth && typeof auth === 'string' && auth.toLowerCase().startsWith('bearer ')) {\n  const token = auth.slice(7).trim();\n  try {\n    const parts = token.split('.');\n    if (parts.length === 3) {\n      const payload = JSON.parse(Buffer.from(parts[1], 'base64').toString('utf8'));\n      organizationId = payload.organization_id ?? payload.organizationId ?? null;\n    }\n  } catch (e) { node.warn('JWT decode failed: ' + (e && e.message)); }\n}\nmsg.organization_id = organizationId;\nreturn msg;",
