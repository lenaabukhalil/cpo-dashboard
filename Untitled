 return [msg, null];\n}\n\nconst allowedStatus = ['online', 'offline'];\nconst conditions = [];\nconst params = [];\n\nmsg._single = false;\n\nif (status) {\n  if (!allowedStatus.includes(status)) {\n    msg.statusCode = 400;\n    msg.payload = { success: false, message: 'Invalid status value. Allowed: online, offline' };\n    return [null, msg];\n  }\n  conditions.push('c.status = ?');\n  params.push(status);\n}\n\nif (locationId) {\n  conditions.push('c.location_id = ?');\n  params.push(locationId);\n}\n\nconst whereClause = conditions.length ? `WHERE ${conditions.join(' AND ')}` : '';\n\nmsg.topic = `\nSELECT c.charger_id AS id, c.name, c.chargerID, c.ocpi_last_update AS time, c.status, c.type, c.location_id AS locationId, c.max_session_time, c.num_connectors, c.description\nFROM ocpp_CSGO.Chargers c\n${whereClause}\nORDER BY c.ocpi_last_update DESC;\n`;\nmsg.payload = params;\nreturn [msg, null];",
