    {
        "id": "fn_leadership_map",
        "type": "function",
        "z": "253add6a74e2ea05",
        "name": " response",
        "func": "const rows = Array.isArray(msg.payload) ? msg.payload : [];\n\nconst data = rows.map(r => ({\n  firstName: r[\"First Name\"] || \"\",\n  lastName:  r[\"Last Name\"] || \"\",\n  count:     Number(r.Count || 0),\n  mobile:    r.Mobile || \"\",\n  energy:    Number(r.Energy || 0),\n  amount:    Number(r.Amount || 0)\n}));\n\nmsg.payload = {\n  success: true,\n  count: data.length,\n  data\n};\n\nreturn msg;",
