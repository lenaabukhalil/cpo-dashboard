        "name": "CPO Router",
        "func": "\n// Output 1: OCPP DB | Output 2: ION DB | Output 3: HTTP response (أخطاء)\n\nfunction badRequest(message) {\n  msg.statusCode = 400;\n  msg.payload = { success: false, message };\n  return [null, null, msg];\n}\n\nconst req = msg.req || {};\nconst q = req.query || {};\nconst path = (req._parsedUrl && req._parsedUrl.pathname) || req.path || (req.url || \"\").split(\"?\")[0];\n\nmsg.correlationId = msg._msgid;\n\nconst orgId = msg.organization_id != null && msg.organization_id !== '' ? msg.organization_id : null;\nconst cpoPaths = [\n  '/api/v4/cpo/active-sessions', '/api/v4/cpo/local-sessions', '/api/v4/cpo/sessions-report',\n  '/api/v4/cpo/active-sessions-history', '/api/v4/cpo/stats', '/api/v4/cpo/connectors-status',\n  '/api/v4/cpo/charger-comparison', '/api/v4/cpo/connector-comparison'\n];\nif (cpoPaths.indexOf(path) !== -1 && (orgId == null || orgId === '')) {\n  msg.statusCode = 403;\n  msg.payload = { success: false, message: 'Organization context required for this endpoint' };\n  return [null, null, msg];\n}\n\nfunction getMobile() { return (q.mobile || \"\").toString().trim(); }\n\nswitch (path) {\n  case \"/api/v4/cpo/sessions-report\": {\n  const fromRaw = (q.from || \"\").toString().trim();\n  const toRaw = (q.to || \"\").toString().trim();\n  if (!fromRaw || !toRaw) return badRequest(\"from and to (YYYY-MM-DD) are required\");\n  const fromDate = new Date(fromRaw);\n  const toDate = new Date(toRaw);\n  if (isNaN(fromDate.getTime()) || isNaN(toDate.getTime())) return badRequest(\"from and to must be valid dates\");\n  if (fromDate > toDate) return badRequest(\"from must be before or equal to to\");\n  const toDateEnd = new Date(toDate);\n  toDateEnd.setDate(toDateEnd.getDate() + 1);\n  const toEnd = toDateEnd.toISOString().slice(0, 10);\n  const locationId = (q.locationId || \"\").toString().trim();\n  const chargerId = (q.chargerId || \"\").toString().trim();\n  const connectorId = (q.connectorId || \"\").toString().trim();\n  const energyMin = (q.energyMin || \"\").toString().trim();\n  const energyMax = (q.energyMax || \"\").toString().trim();\n  const whereParts = [\n    \"PB.issue_date >= ?\",\n    \"PB.issue_date < ?\",\n    \"PB.total_amount > 0\",\n    \"L.organization_id = ?\"\n  ];\n  const payload = [fromRaw, toEnd, orgId];\n  if (locationId) { whereParts.push(\"C.location_id = ?\"); payload.push(locationId); }\n  if (chargerId) { whereParts.push(\"PB.charger_id = ?\"); payload.push(chargerId); }\n  if (connectorId) { whereParts.push(\"PB.connector_id = ?\"); payload.push(connectorId); }\n  if (energyMin !== \"\") {\n    const n = Number(energyMin);\n    if (!Number.isFinite(n)) return badRequest(\"energyMin must be a number\");\n    whereParts.push(\"PB.total_kwh >= ?\");\n    payload.push(energyMin);\n  }\n  if (energyMax !== \"\") {\n    const n = Number(energyMax);\n    if (!Number.isFinite(n)) return badRequest(\"energyMax must be a number\");\n    whereParts.push(\"PB.total_kwh <= ?\");\n    payload.push(energyMax);\n  }\n  msg.operation = \"GET_SESSIONS_REPORT\";\n  msg.topic = `\nSELECT PB.issue_date AS \"Start Date/Time\", PB.session_id AS \"Session ID\", L.name AS \"Location\",\n  C.charger_id AS \"Charger\", Co.connector_type AS \"Connector\",\n  ROUND(PB.total_kwh, 2) AS \"Energy (KWH)\", ROUND(PB.total_amount, 2) AS \"Amount (JOD)\", PB.issued_to AS \"mobile\"\nFROM ocpp_CSGO.Partner_Bill PB\nLEFT JOIN ocpp_CSGO.Chargers C ON PB.charger_id = C.charger_id\nLEFT JOIN ocpp_CSGO.Connectors Co ON PB.connector_id = Co.connector_id AND PB.charger_id = Co.charger_id\nLEFT JOIN ocpp_CSGO.Locations L ON C.location_id = L.location_id\nWHERE ${whereParts.join(\" AND \")}\nORDER BY PB.session_id DESC;`;\n  msg.payload = payload;\n  return [msg, null, null];\n}\n  case \"/api/v4/cpo/connectors-status\": {\n    msg.operation = \"GET_CONNECTORS_STATUS_ALL\";\n    msg.topic = `\nSELECT Co.connector_id AS connectorId, COALESCE(Co.connector_type, '') AS connectorType, COALESCE(Co.status, '') AS status,\n  C.charger_id AS chargerId, C.name AS chargerName, COALESCE(C.status, '') AS chargerStatus, L.name AS locationName, COALESCE(O.name, '') AS organizationName\nFROM ocpp_CSGO.Connectors Co\nJOIN ocpp_CSGO.Chargers C ON C.charger_id = Co.charger_id\nJOIN ocpp_CSGO.Locations L ON L.location_id = C.location_id\nLEFT JOIN ocpp_CSGO.Organizations O ON O.organization_id = L.organization_id\nWHERE L.organization_id = ?\nORDER BY organizationName, locationName, chargerName, Co.connector_id;`;\n    msg.payload = [orgId];\n    return [msg, null, null];\n  }\n  case \"/api/v4/cpo/connector-comparison\": {\n    const startRaw = (q.start || \"\").toString().trim(), endRaw = (q.end || \"\").toString().trim();\n    const locationId = (q.locationId || \"\").toString().trim(), chargerId = (q.chargerId || \"\").toString().trim();\n    const connectorIds = (q.connectorIds || \"\").toString().trim().split(\",\").map(s => s.trim()).filter(Boolean);\n    let startDate = \"2020-01-01\", endDate = \"2030-12-31\";\n    if (startRaw) { const d = new Date(startRaw); if (!isNaN(d.getTime())) startDate = d.toISOString().slice(0, 10); }\n    if (endRaw) { const d = new Date(endRaw); if (!isNaN(d.getTime())) endDate = d.toISOString().slice(0, 10); }\n    const endExcl = new Date(endDate); endExcl.setDate(endExcl.getDate() + 1);\n    const whereParts = [\"L.organization_id = ?\"], payload = [startDate, endExcl.toISOString().slice(0, 10), orgId];\n    if (locationId) { whereParts.push(\"C.location_id = ?\"); payload.push(locationId); }\n    if (chargerId) { whereParts.push(\"Co.charger_id = ?\"); payload.push(chargerId); }\n    if (connectorIds.length) { whereParts.push(\"Co.connector_id IN (\" + connectorIds.map(() => \"?\").join(\",\") + \")\"); payload.push(...connectorIds); }\n    msg.operation = \"GET_CONNECTOR_COMPARISON\";\n    msg.topic = `\nSELECT Co.connector_id AS connectorId, Co.charger_id AS chargerId, C.name AS chargerName, COALESCE(Co.connector_type, '') AS connectorType,\