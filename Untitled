        "name": "Dashboard Router ",
        "func": "// One router for all dashboard endpoints.\n// Output 1: OCPP DB\n// Output 2: ION DB\n// Output 3: direct HTTP response (validation errors)\n\nfunction badRequest(message) {\n  msg.statusCode = 400;\n  msg.payload = { success: false, message };\n  return [null, null, msg];\n}\n\nconst req = msg.req || {};\nconst q = req.query || {};\nconst path =\n  (req._parsedUrl && req._parsedUrl.pathname) ||\n  req.path ||\n  (req.url || \"\").split(\"?\")[0];\n\nmsg.correlationId = msg._msgid;\n\nfunction getMobile() {\n  return (q.mobile || \"\").toString().trim();\n}\n\nswitch (path) {\n  case \"/api/v4/dashboard/sessions-report\": {\n    const from = (q.from || \"\").toString().trim() || \"2025-01-01\";\n    const to = (q.to || \"\").toString().trim() || \"2026-12-31\";\n\n    const toDate = new Date(to);\n    toDate.setDate(toDate.getDate() + 1);\n    const toEnd = toDate.toISOString().slice(0, 10);\n\n    msg.operation = \"GET_SESSIONS_REPORT\";\n    msg.topic = `\nSELECT\n  PB.issue_date AS \"Start Date/Time\",\n  PB.session_id AS \"Session ID\",\n  L.name        AS \"Location\",\n  C.charger_id  AS \"Charger\",\n  Co.connector_type AS \"Connector\",\n  ROUND(PB.total_kwh, 2)    AS \"Energy (KWH)\",\n  ROUND(PB.total_amount, 2) AS \"Amount (JOD)\",\n  PB.issued_to  AS \"mobile\"\nFROM ocpp_CSGO.Partner_Bill PB\nLEFT JOIN ocpp_CSGO.Chargers   C  ON PB.charger_id   = C.charger_id\nLEFT JOIN ocpp_CSGO.Connectors Co ON PB.connector_id = Co.connector_id\n                               AND PB.charger_id   = Co.charger_id\nLEFT JOIN ocpp_CSGO.Locations  L  ON C.location_id   = L.location_id\nWHERE PB.issue_date >= ?\n  AND PB.issue_date < ?\n  AND PB.total_amount > 0\nORDER BY PB.session_id DESC;\n`;\n    msg.payload = [from, toEnd];\n    return [msg, null, null];\n  }\n\n  case \"/api/v4/dashboard/connectors-status\": {\n    msg.operation = \"GET_CONNECTORS_STATUS_ALL\";\n    msg.topic = `\nSELECT\n  Co.connector_id AS connectorId,\n  COALESCE(Co.connector_type, '') AS connectorType,\n  COALESCE(Co.status, '') AS status,\n  C.charger_id AS chargerId,\n  C.name AS chargerName,\n  L.name AS locationName,\n  COALESCE(O.name, '') AS organizationName\nFROM ocpp_CSGO.Connectors Co\nJOIN ocpp_CSGO.Chargers C ON C.charger_id = Co.charger_id\nJOIN ocpp_CSGO.Locations L ON L.location_id = C.location_id\nLEFT JOIN ocpp_CSGO.Organizations O ON O.organization_id = L.organization_id\nORDER BY organizationName, locationName, chargerName, Co.connector_id;\n`;\n    msg.payload = [];\n    return [msg, null, null];\n  }\n  case \"/api/v4/dashboard/connector-comparison\": {\n    const startRaw = (q.start || \"\").toString().trim();\n    const endRaw = (q.end || \"\").toString().trim();\n    const locationId = (q.locationId || \"\").toString().trim();\n    const chargerId = (q.chargerId || \"\").toString().trim();\n    const connectorIdsRaw = (q.connectorIds || \"\").toString().trim();\n\n    const connectorIds = connectorIdsRaw\n      ? connectorIdsRaw.split(\",\").map((s) => s.trim()).filter(Boolean)\n      : [];\n\n    let startDate = \"2020-01-01\";\n    let endDate = \"2030-12-31\";\n\n    if (startRaw) {\n      const d = new Date(startRaw);\n      if (isNaN(d.getTime())) return badRequest(\"Invalid start date\");\n      startDate = d.toISOString().slice(0, 10);\n    }\n    if (endRaw) {\n      const d = new Date(endRaw);\n      if (isNaN(d.getTime())) return badRequest(\"Invalid end date\");\n      endDate = d.toISOString().slice(0, 10);\n    }\n\n    const endDateExclusive = new Date(endDate);\n    endDateExclusive.setDate(endDateExclusive.getDate() + 1);\n    const endDateExclusiveStr = endDateExclusive.toISOString().slice(0, 10);\n\n    const whereParts = [];\n    const payload = [startDate, endDateExclusiveStr];\n\n    if (locationId) {\n      whereParts.push(\"C.location_id = ?\");\n      payload.push(locationId);\n    }\n    if (chargerId) {\n      whereParts.push(\"Co.charger_id = ?\");\n      payload.push(chargerId);\n    }\n    if (connectorIds.length) {\n      whereParts.push(\n        \"Co.connector_id IN (\" + connectorIds.map(() => \"?\").join(\",\") + \")\"\n      );\n      payload.push(...connectorIds);\n    }\n\n    const whereClause = whereParts.length ? \"AND \" + whereParts.join(\" AND \") : \"\";\n\n    msg.operation = \"GET_CONNECTOR_COMPARISON\";\n    msg.topic = `\nSELECT\n  Co.connector_id AS connectorId,\n  Co.charger_id   AS chargerId,\n  C.name          AS chargerName,\n  COALESCE(Co.connector_type, '') AS connectorType,\n  COALESCE(Co.status, '')         AS status,\n  L.name          AS locationName,\n  COALESCE(S.sessionsCount, 0) AS sessionsCount,\n  ROUND(COALESCE(S.totalKwh, 0), 2)    AS totalKwh,\n  ROUND(COALESCE(S.totalAmount, 0), 2) AS totalAmount\nFROM ocpp_CSGO.Connectors Co\nLEFT JOIN ocpp_CSGO.Chargers  C ON C.charger_id  = Co.charger_id\nLEFT JOIN ocpp_CSGO.Locations L ON L.location_id = C.location_id\nLEFT JOIN (\n  SELECT\n    PB.connector_id,\n    PB.charger_id,\n    COUNT(*)               AS sessionsCount,\n    SUM(PB.total_kwh)      AS totalKwh,\n    SUM(PB.total_amount)   AS totalAmount\n  FROM ocpp_CSGO.Partner_Bill PB\n  WHERE PB.issue_date >= ?\n    AND PB.issue_date < ?\n  GROUP BY PB.connector_id, PB.charger_id\n) S ON S.connector_id = Co.connector_id\n   AND S.charger_id   = Co.charger_id\nWHERE 1=1\n${whereClause}\nORDER BY Co.charger_id, Co.connector_id;\n`;\n    msg.payload = payload;\n    return [msg, null, null];\n  }\n\n  case \"/api/v4/dashboard/charger-comparison\": {\n    const startRaw = (q.start || \"\").toString().trim();\n    const endRaw = (q.end || \"\").toString().trim();\n    const locationId = (q.locationId || \"\").toString().trim();\n    const chargerIdsRaw = (q.chargerIds || \"\").toString().trim();\n\n    const chargerIds = chargerIdsRaw\n      ? chargerIdsRaw.split(\",\").map((s) => s.trim()).filter(Boolean)\n      : [];\n\n    let startDate = \"2020-01-01\";\n    let endDate = \"2030-12-31\";\n\n    if (startRaw) {\n      const d = new Date(startRaw);\n      if (isNaN(d.getTime())) return badRequest(\"Invalid start date\");\n      startDate = d.toISOString().slice(0, 10);\n    }\n    if (endRaw) {\n      const d = new Date(endRaw);\n      if (isNaN(d.getTime())) return badRequest(\"Invalid end date\");\n      endDate = d.toISOString().slice(0, 10);\n    }\n\n    const endDateExclusive = new Date(endDate);\n    endDateExclusive.setDate(endDateExclusive.getDate() + 1);\n    const endDateExclusiveStr = endDateExclusive.toISOString().slice(0, 10);\n\n    const whereParts = [];\n    const payload = [startDate, endDateExclusiveStr];\n\n    if (locationId) {\n      whereParts.push(\"C.location_id = ?\");\n      payload.push(locationId);\n    }\n    if (chargerIds.length) {\n      whereParts.push(\n        \"C.charger_id IN (\" + chargerIds.map(() => \"?\").join(\",\") + \")\"\n      );\n      payload.push(...chargerIds);\n    }\n\n    const whereClause = whereParts.length ? \"AND \" + whereParts.join(\" AND \") : \"\";\n\n    msg.operation = \"GET_CHARGER_COMPARISON\";\n    msg.topic = `\nSELECT\n  C.charger_id AS chargerId,\n  C.name       AS name,\n  COALESCE(C.type, '')   AS type,\n  COALESCE(C.status, '') AS status,\n  L.location_id          AS locationId,\n  L.name                 AS locationName,\n  COALESCE(ConnAgg.connectorsCount, 0) AS connectorsCount,\n  (LOWER(C.status) = 'online')         AS onlineFlag,\n  COALESCE(S.sessionsCount, 0)         AS sessionsCount,\n  ROUND(COALESCE(S.totalKwh, 0), 2)    AS totalKwh,\n  ROUND(COALESCE(S.totalAmount, 0), 2) AS totalAmount\nFROM ocpp_CSGO.Chargers C\nLEFT JOIN ocpp_CSGO.Locations L ON L.location_id = C.location_id\nLEFT JOIN (\n  SELECT charger_id, COUNT(*) AS connectorsCount\n  FROM ocpp_CSGO.Connectors\n  GROUP BY charger_id\n) ConnAgg ON ConnAgg.charger_id = C.charger_id\nLEFT JOIN (\n  SELECT\n    PB.charger_id,\n    COUNT(*)             AS sessionsCount,\n    SUM(PB.total_kwh)    AS totalKwh,\n    SUM(PB.total_amount) AS totalAmount\n  FROM ocpp_CSGO.Partner_Bill PB\n  WHERE PB.issue_date >= ?\n    AND PB.issue_date < ?\n  GROUP BY PB.charger_id\n) S ON S.charger_id = C.charger_id\nWHERE 1=1\n${whereClause}\nORDER BY C.charger_id;\n`;\n    msg.payload = payload;\n    return [msg, null, null];\n  }\n\n  case \"/api/v4/dashboard/active-sessions\": {\n    msg.operation = \"GET_ACTIVE_SESSIONS\";\n    msg.topic = `\nSELECT\n  Sessions.start_date AS \"Start Date/Time\",\n  Sessions.session_id AS \"Session ID\",\n  Locations.name      AS \"Location\",\n  Chargers.name       AS \"Charger\",\n  Connectors.connector_type AS \"Connector\",\n  ROUND(Sessions.kwh,   2) AS \"Energy (KWH)\",\n  ROUND(Sessions.amount,2) AS \"Amount (JOD)\",\n  Sessions.user_id          AS \"mobile\",\n  Sessions.end_date         AS \"end_date\",\n  Sessions.duration         AS \"duration\",\n  Sessions.stop_reason      AS \"stop_reason\"\nFROM ocpp_CSGO.Sessions\nRIGHT JOIN ocpp_CSGO.Connectors ON Connectors.connector_id = Sessions.connector_id\nRIGHT JOIN ocpp_CSGO.Chargers  ON Chargers.charger_id   = Sessions.charger_id\nRIGHT JOIN ocpp_CSGO.Locations ON Locations.location_id = Chargers.location_id\nWHERE active = 1 AND charging=1\nGROUP BY Sessions.session_id\nORDER BY Sessions.session_id DESC;\n`;\n    msg.payload = [];\n    return [msg, null, null];\n  }\n\n  case \"/api/v4/dashboard/local-sessions\": {\n    msg.operation = \"GET_LOCAL_SESSIONS\";\n    msg.topic = `\nSELECT\n  Sessions_local.start_date AS \"Start Date/Time\",\n  Sessions_local.session_id  AS \"session_id\",\n  Locations.name            AS \"Location\",\n  Chargers.name             AS \"Charger\",\n  Connectors.connector_type AS \"Connector\",\n  ROUND(Sessions_local.total_kwh,   2) AS \"Energy (KWH)\",\n  ROUND(Sessions_local.total_amount,2) AS \"Amount (JOD)\",\n  Sessions_local.user_id    AS \"User ID\",\n  Sessions_local.end_date   AS \"end_date\",\n  Sessions_local.duration   AS \"duration\",\n  Sessions_local.stop_reason AS \"stop_reason\"\nFROM ocpp_CSGO.Sessions_local\nRIGHT JOIN ocpp_CSGO.Connectors ON Sessions_local.connector_id = Connectors.connector_id\nRIGHT JOIN ocpp_CSGO.Chargers  ON Chargers.charger_id          = Sessions_local.charger_id\nRIGHT JOIN ocpp_CSGO.Locations ON Locations.location_id        = Chargers.location_id\nWHERE active = 1 AND Sessions_local.start_date > '2025-10-01'\nGROUP BY Sessions_local.session_id\nORDER BY Sessions_local.session_id DESC;\n`;\n    msg.payload = [];\n    return [msg, null, null];\n  }\n\n  case \"/api/v4/dashboard/user-info\": {\n    const mobile = getMobile();\n    if (!mobile || mobile.length < 10) return badRequest(\"mobile is required\");\n    msg.operation = \"GET_USER_INFO\";\n    msg.topic = `\nSELECT mobile, first_name, last_name, ROUND(balance,2) AS balance, language, device_id\nFROM user_profiles\nWHERE mobile = ?;\n`;\n    msg.payload = [mobile];\n    return [null, msg, null];\n  }\n\n  case \"/api/v4/dashboard/user-sessions\": {\n    const mobile = getMobile();\n    if (!mobile || mobile.length < 10) return badRequest(\"mobile is required\");\n    msg.operation = \"GET_USER_SESSIONS\";\n    msg.topic = `\nSELECT start_date AS \"Date/Time\", charger_id AS \"Charger\", kwh AS \"Energy\", amount AS \"Amount\"\nFROM charger_sessions\nWHERE user_id = ?\nORDER BY session_id DESC\nLIMIT 20;\n`;\n    msg.payload = [mobile];\n    return [null, msg, null];\n  }\n\n  case \"/api/v4/dashboard/user-payments\": {\n    const mobile = getMobile();\n    if (!mobile || mobile.length < 10) return badRequest(\"mobile is required\");\n    msg.operation = \"GET_USER_PAYMENTS\";\n    msg.topic = `\nSELECT\n  timestamp AS \"Date/Time\",\n  source    AS \"Source\",\n  amount    AS \"Amount (JOD)\"\nFROM user_payments\nWHERE mobile = ? AND type = 'C'\nORDER BY timestamp DESC\nLIMIT 20;\n`;\n    msg.payload = [mobile];\n    return [null, msg, null];\n  }\n\n  case \"/api/v4/dashboard/stats\": {\n    const base = msg;\n    const ocppMsg = Object.assign({}, base);\n    ocppMsg.operation = \"GET_STATS_OCPP\";\n    ocppMsg.topic = `\nSELECT\n  (SELECT COUNT(*) FROM ocpp_CSGO.Sessions   WHERE active=1 AND charging=1) AS activeSessions,\n  (SELECT COUNT(*) FROM ocpp_CSGO.Chargers   WHERE LOWER(status)='online')  AS chargersOnline,\n  (SELECT COUNT(*) FROM ocpp_CSGO.Connectors WHERE enabled=1)              AS totalConnectors,\n  (SELECT COUNT(*) FROM ocpp_CSGO.Connectors WHERE LOWER(status)='busy')   AS busyConnectors;\n`;\n    ocppMsg.payload = [];\n    const ionMsg = Object.assign({}, base);\n    ionMsg.operation = \"GET_STATS_ION\";\n    ionMsg.topic = `\nSELECT\n  (SELECT COUNT(*) FROM user_profiles WHERE creation_date > CURDATE()) AS newUsers,\n  (SELECT COUNT(*) FROM charger_sessions WHERE start_date > CURDATE() AND amount>0) AS sessions,\n  (SELECT IFNULL(SUM(PaidAmt),0) FROM BLRPMTNTFRQ WHERE PmtStatus='PmtNew' AND TmStp > CURDATE()) AS eFawateerCom,\n  (SELECT IFNULL(SUM(amount),0) FROM ni_orders WHERE status='success' AND \\`time\\` > CURDATE()) AS ni,\n  (SELECT IFNULL(ROUND(SUM(amount),2),0) FROM orange_money_transactions WHERE timestamp > CURDATE()) AS orangeMoney,\n  (SELECT IFNULL(ROUND(SUM(amount),2),0) FROM charger_sessions WHERE amount>0 AND end_date > CURDATE()) AS expendature;\n`;\n    ionMsg.payload = [];\n    return [ocppMsg, ionMsg, null];\n  }\n\n  case \"/api/v4/dashboard/charger-status\": {\n    const chargerIdRaw = (q.chargerId || \"\").toString().trim();\n    if (!chargerIdRaw) return badRequest(\"chargerId is required\");\n    const chargerId = Number(chargerIdRaw);\n    if (!Number.isFinite(chargerId)) return badRequest(\"chargerId must be a number\");\n    msg.operation = \"GET_CHARGER_STATUS\";\n    msg.topic = `\nSELECT status\nFROM ocpp_CSGO.Connectors\nWHERE charger_id = ?\nLIMIT 1;\n`;\n    msg.payload = [chargerId];\n    return [msg, null, null];\n  }\n\n  case \"/api/v4/dashboard/connector-status\": {\n    const connectorIdRaw = (q.connectorId || \"\").toString().trim();\n    if (!connectorIdRaw) return badRequest(\"connectorId is required\");\n    const connectorId = Number(connectorIdRaw);\n    if (!Number.isFinite(connectorId)) return badRequest(\"connectorId must be a number\");\n    msg.operation = \"GET_CONNECTOR_STATUS\";\n    msg.topic = `\nSELECT status\nFROM ocpp_CSGO.Connectors\nWHERE connector_id = ?\nLIMIT 1;\n`;\n    msg.payload = [connectorId];\n    return [msg, null, null];\n  }\n\n  case \"/api/v4/dashboard/active-sessions-history\": {\n    const hoursRaw = (q.hours || \"24\").toString().trim();\n    const hours = Math.max(1, Math.min(48, Math.floor(Number(hoursRaw) || 24)));\n    const stepMin = 5;\n    const points = Math.floor((hours * 60) / stepMin);\n    const digits = `(SELECT 0 n UNION ALL SELECT 1 UNION ALL SELECT 2 UNION ALL SELECT 3 UNION ALL SELECT 4\n                  UNION ALL SELECT 5 UNION ALL SELECT 6 UNION ALL SELECT 7 UNION ALL SELECT 8 UNION ALL SELECT 9)`;\n    const hundreds = `(SELECT 0 n UNION ALL SELECT 1 UNION ALL SELECT 2 UNION ALL SELECT 3 UNION ALL SELECT 4 UNION ALL SELECT 5)`;\n    msg.operation = \"GET_ACTIVE_SESSIONS_HISTORY\";\n    msg.topic = `\nSELECT\n  UNIX_TIMESTAMP(t.ts) * 1000 AS ts,\n  COUNT(s.session_id) AS count\nFROM (\n  SELECT\n    TIMESTAMP(DATE_FORMAT(NOW() - INTERVAL ${hours} HOUR, '%Y-%m-%d %H:%i:00'))\n      + INTERVAL (n*${stepMin}) MINUTE AS ts\n  FROM (\n    SELECT (a.n + b.n*10 + c.n*100) AS n\n    FROM ${digits} a\n    CROSS JOIN ${digits} b\n    CROSS JOIN ${hundreds} c\n  ) nums\n  WHERE n < ${points}\n) t\nLEFT JOIN ocpp_CSGO.Sessions s\n  ON s.start_date <= t.ts\n AND (\n   COALESCE(\n     s.end_date,\n     s.start_date + INTERVAL TIME_TO_SEC(COALESCE(s.duration, '00:00:00')) SECOND\n   ) > t.ts\n )\nGROUP BY t.ts\nORDER BY t.ts;\n`;\n    msg.payload = [];\n    return [msg, null, null];\n  }\n\n  default:\n    msg.statusCode = 404;\n    msg.payload = { success: false, message: \"Not Found\" };\n    return [null, null, msg];\n}\n",
