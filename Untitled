        "func": "function asNumber(v) {\n  if (typeof v === \"number\") return Number.isFinite(v) ? v : 0;\n  const s = String(v ?? \"\").trim();\n  const n = Number(s);\n  return Number.isFinite(n) ? n : 0;\n}\n\n// Handle upstream errors\nif (msg.statusCode && msg.statusCode >= 400) {\n  msg.statusCode = 502;\n  msg.payload = {\n    success: false,\n    message: \"Failed to fetch SMS balance\",\n    upstreamStatus: msg.statusCode,\n  };\n  return msg;\n}\n\nconst smsBalance = asNumber(msg.payload);\n\nmsg.statusCode = 200;\nmsg.payload = {\n  success: true,\n  data: {\n    smsBalance,\n  },\n};\n\nreturn msg;",
