nSELECT C.charger_id AS chargerId, C.name AS name, COALESCE(C.type, '') AS type, COALESCE(C.status, '') AS status,\n  L.location_id AS locationId, L.name AS locationName, COALESCE(ConnAgg.connectorsCount, 0) AS connectorsCount,\n  (LOWER(C.status) = 'online') AS onlineFlag, COALESCE(S.sessionsCount, 0) AS sessionsCount,\n  ROUND(COALESCE(S.totalKwh, 0), 2) AS totalKwh, ROUND(COALESCE(S.totalAmount, 0), 2) AS totalAmount\nFROM ocpp_CSGO.Chargers C\nLEFT JOIN ocpp_CSGO.Locations L ON L.location_id = C.location_id\nLEFT JOIN (SELECT charger_id, COUNT(*) AS connectorsCount FROM ocpp_CSGO.Connectors GROUP BY charger_id) ConnAgg ON ConnAgg.charger_id = C.charger_id\nLEFT JOIN (SELECT PB.charger_id, COUNT(*) AS sessionsCount, SUM(PB.total_kwh) AS totalKwh, SUM(PB.total_amount) AS totalAmount\n  FROM ocpp_CSGO.Partner_Bill PB WHERE PB.issue_date >= ? AND PB.issue_date < ? GROUP BY PB.charger_id) S ON S.charger_id = C.charger_id\nWHERE 1=1 AND ${whereParts.join(\" AND \")} ORDER BY C.charger_id;`;\n    msg.payload = payload;\n    return [msg, null, null];\n  }\n  case \"/api/v4/cpo/active-sessions\": {\n    msg.operation = \"GET_ACTIVE_SESSIONS\";\n    msg.topic = `\nSELECT Sessions.start_date AS \"Start Date/Time\", Sessions.session_id AS \"Session ID\", Locations.name AS \"Location\", Chargers.name AS \"Charger\",\n  Connectors.connector_type AS \"Connector\", ROUND(Sessions.kwh, 2) AS \"Energy (KWH)\", ROUND(Sessions.amount, 2) AS \"Amount (JOD)\",\n  Sessions.user_id AS \"mobile\", Sessions.end_date AS \"end_date\", Sessions.duration AS \"duration\", Sessions.stop_reason AS \"stop_reason\"\nFROM ocpp_CSGO.Sessions\nRIGHT JOIN ocpp_CSGO.Connectors ON Connectors.connector_id = Sessions.connector_id\nRIGHT JOIN ocpp_CSGO.Chargers ON Chargers.charger_id = Sessions.charger_id\nRIGHT JOIN ocpp_CSGO.Locations ON Locations.location_id = Chargers.location_id\nWHERE active = 1 AND charging = 1 AND Locations.organization_id = ?\nGROUP BY Sessions.session_id ORDER BY Sessions.sessio