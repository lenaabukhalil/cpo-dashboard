    {
        "id": "fn_leadership_query",
        "type": "function",
        "z": "253add6a74e2ea05",
        "name": "Build SQL",
        "func": "const qry = `\nSELECT \n  (SELECT first_name FROM user_profiles WHERE mobile = user_id) AS \"First Name\",\n  (SELECT last_name  FROM user_profiles WHERE mobile = user_id) AS \"Last Name\",\n  COUNT(*) AS Count,\n  user_id AS Mobile,\n  ROUND(SUM(kwh), 3) AS Energy,\n  ROUND(SUM(amount), 3) AS Amount\nFROM Sessions\nWHERE kwh > 0\nGROUP BY mobile\nORDER BY Count DESC\nLIMIT 10;\n`;\n\nmsg.topic = qry;\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 490,
        "y": 1660,
